{
    "name": "hbagheri/string-logic-check",
    "description": "Evaluate boolean expression strings with AND/OR/NOT operators (case-insensitive, multiple aliases).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hassan Bagheri",
            "email": "hbagheri@glenar.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "StringLogicCheck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StringLogicCheck\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "demo": "php index.php"
    }
}
